# OMEGA-ZSH {{ version }} (Python/Jinja2 Generated)
# --- HYPERDRIVE PERFORMANCE ENGINE ---
# 1. Modo Asíncrono para sugerencias (evita lag al escribir)
export ZSH_AUTOSUGGEST_USE_ASYNC=1
export ZSH_AUTOSUGGEST_BUFFER_MAX_SIZE=20

# 2. Desactivar escaneo de Git pesado (Turbo Prompt)
export DISABLE_UNTRACKED_FILES_DIRTY="true"
export GIT_PS1_SHOWDIRTYSTATE=""

# 3. Z-Compile (Compilación automática a Bytecode)
# Esto hace que los plugins se carguen 10 veces más rápido
function omega_zcompile() {
    local zfile=$1
    if [[ -f "$zfile" ]]; then
        if [[ ! -f "${zfile}.zwc" || "$zfile" -nt "${zfile}.zwc" ]]; then
            zsh -c "zcompile $zfile" 2>/dev/null
        fi
    fi
}

# Aplicar a los archivos base de Oh My Zsh
export ZSH="{{ omz_dir }}"
for _f in $ZSH/oh-my-zsh.sh $ZSH/lib/*.zsh; do omega_zcompile $_f; done

export TERM=xterm-256color
export COLORTERM=truecolor

# Ensure User Python Binaries are in PATH
export PATH="$HOME/.local/bin:$PATH"

{% if is_termux %}
export GYP_DEFINES="android_ndk_path=''"
export FZF_BASE=$PREFIX/bin/fzf
{% endif %}

# Theme selection
if [ "$(id -u)" -eq 0 ]; then
    ZSH_THEME="{{ root_theme }}"
else
    ZSH_THEME="{{ user_theme }}"
fi

# Plugins selection
plugins=({% for plugin in plugins %}{{ plugin }} {% endfor %})

source $ZSH/oh-my-zsh.sh

# --- Optimización de arranque ---
# compinit con caché: evita compaudit en cada inicio (ahorra ~60ms)
autoload -Uz compinit
if [[ -f ~/.zcompdump && $(date +%j) == $(date +%j -r ~/.zcompdump 2>/dev/null || echo 0) ]]; then
    compinit -C  # Carga desde caché sin re-auditar
else
    compinit     # Re-genera caché una vez al día
fi

{% if default_user %}
export DEFAULT_USER="{{ default_user }}"
{% endif %}

# --- Modern Tools Configuration ---
{% if 'zoxide' in active_tools %}
eval "$(zoxide init zsh)"
{% endif %}

{% if 'eza' in active_tools %}
alias ls="eza --icons --group-directories-first"
alias ll="eza -lh --icons --group-directories-first"
alias la="eza -lah --icons --group-directories-first"
{% endif %}

# --- DEFAULT EDITOR ---
export EDITOR='nano'
export VISUAL='nano'


{% if 'yazi' in active_tools %}
function yy() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
	yazi "$@" --cwd-file="$tmp"
	if cwd="$(cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
		builtin cd -- "$cwd"
	fi
	rm -f -- "$tmp"
}
{% endif %}

# --- Root/Sudo Logic ---
{% if is_termux %}
if [ -x "$(command -v su)" ]; then
    # Fallback for Termux if tsu is missing: handle arguments or default to shell
    unalias sudo 2>/dev/null
    sudo() {
        if [ "$#" -eq 0 ]; then
            su -c "unset LD_PRELOAD; export PATH=$PREFIX/bin:$PATH; export HOME=$HOME; exec zsh"
        else
            su -c "unset LD_PRELOAD; export PATH=$PREFIX/bin:$PATH; export HOME=$HOME; \"$@\""
        fi
    }
elif command -v tsu > /dev/null 2>&1; then
    alias sudo='tsu'
fi

{% endif %}

# --- Header ---
{% if header_cmd %}
{{ header_cmd }}
{% endif %}

# --- User Customizations ---
# Cargamos primero el archivo estructurado personal
[[ -f "{{ personal_zsh }}" ]] && source "{{ personal_zsh }}"

# Luego cualquier ajuste manual extra
[[ -f "{{ custom_zsh }}" ]] && source "{{ custom_zsh }}"
