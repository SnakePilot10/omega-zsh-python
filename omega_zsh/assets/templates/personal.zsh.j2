# Omega-ZSH personal configuration.
# This file is intentionally minimal and only renders explicit user data.

{% for path in extra_paths %}
if [ -d "{{ path }}" ]; then
    export PATH="{{ path }}:$PATH"
fi
{% endfor %}

{% for key, value in env_vars.items() %}
export {{ key }}="{{ value }}"
{% endfor %}

{% for name, cmd in aliases.items() %}
alias {{ name }}='{{ cmd }}'
{% endfor %}
