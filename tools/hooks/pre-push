#!/usr/bin/env bash
set -euo pipefail

if [ "${OMEGA_SKIP_HOOK:-}" = "1" ]; then
    echo "⚠️  OMEGA_SKIP_HOOK=1 detectado. Saltando validación pre-push."
    exit 0
fi

echo "🚀 Validando cambios antes del push..."

if [ -d ".venv" ]; then
    # shellcheck disable=SC1091
    source .venv/bin/activate
else
    echo "❌ Error: No se encontró el entorno virtual (.venv)"
    echo "💡 Ejecuta ./install.sh o crea el entorno antes de usar este hook."
    exit 1
fi

echo "🧹 Ejecutando Ruff check..."
ruff check .

echo "🎨 Verificando formato Ruff..."
ruff format --check .

echo "✅ Validación pre-push completada."
exit 0
